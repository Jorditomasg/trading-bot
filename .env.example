# ── Binance credentials ───────────────────────────────────────────────────────
BINANCE_API_KEY=your_testnet_api_key
BINANCE_API_SECRET=your_testnet_api_secret
BINANCE_TESTNET=true          # set to false for mainnet

# ── Telegram (optional) ───────────────────────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
TELEGRAM_ENABLED=true

# ── Capital ───────────────────────────────────────────────────────────────────
INITIAL_CAPITAL=10000         # fallback when Binance API is unreachable

# ── Encryption ────────────────────────────────────────────────────────────────
FERNET_KEY=                   # auto-generated on first run — back this up!

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
TZ=UTC
DECIMAL_SEPARATOR=comma       # dot → 1,234.56 | comma → 1.234,56

# ─────────────────────────────────────────────────────────────────────────────
# SYMBOL, TIMEFRAME, and RISK_PER_TRADE are managed in the database — not here.
# On first run the bot seeds these optimized defaults (3yr backtest validated):
#
#   symbol          = BTCUSDT
#   timeframe       = 4h
#   risk_per_trade  = 0.015   → ~17% annual, ~16% max drawdown (Quarter-Kelly)
#   ema_tp_mult     = 4.5
#   ema_stop_mult   = 1.5
#   ema_max_dist    = 1.0
#   long_only       = true
#
# Change them any time from the dashboard CONFIG tab — no restart needed.
# ─────────────────────────────────────────────────────────────────────────────
